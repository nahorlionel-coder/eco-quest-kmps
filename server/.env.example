# PostgreSQL — sesuaikan dengan docker-compose atau install lokal
DATABASE_URL="postgresql://ecoquest:ecoquest@localhost:5432/ecoquest?schema=public"

# JWT — GANTI dengan random string panjang!
JWT_SECRET="ganti-dengan-string-acak-minimal-32-karakter-jangan-pakai-ini"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:5173"

# File upload
UPLOAD_DIR="./uploads"
PUBLIC_URL="http://localhost:3001"

# Google OAuth (opsional — kosongkan kalau tidak pakai)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"
FRONTEND_URL="http://localhost:5173"

# OpenAI (opsional — untuk verify-photo. Kosongkan untuk skip AI verify)
OPENAI_API_KEY=""
